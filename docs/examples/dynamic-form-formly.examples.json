{
  "version": 1,
  "form": {
    "key": "contact_request",
    "title": "Contact request",
    "presentation": {
      "profileKey": "adaptive",
      "kit": "auto",
      "theme": "chicle"
    },
    "steps": [
      {
        "key": "identity",
        "title": "Main data",
        "description": "Information required to identify the request.",
        "fields": [
          {
            "name": "identity_title",
            "type": "title",
            "label": "Contact information",
            "layout": "full"
          },
          {
            "name": "name",
            "type": "text",
            "label": "Name",
            "required": true,
            "transform": "trim",
            "length": {
              "min": 3,
              "max": 80
            }
          },
          {
            "name": "email",
            "type": "email",
            "label": "Email",
            "required": true
          },
          {
            "name": "channel",
            "type": "select",
            "label": "Preferred channel",
            "required": true,
            "options": [
              {
                "label": "Email",
                "value": "email"
              },
              {
                "label": "Phone",
                "value": "phone"
              }
            ]
          },
          {
            "name": "phone",
            "type": "tel",
            "label": "Phone",
            "visibleWhen": {
              "field": "channel",
              "operator": "equals",
              "value": "phone"
            }
          }
        ]
      },
      {
        "key": "preferences",
        "title": "Preferencias",
        "fields": [
          {
            "name": "priority",
            "type": "radio",
            "label": "Prioridad",
            "required": true,
            "layout": "full",
            "options": [
              {
                "label": "Normal",
                "value": "normal"
              },
              {
                "label": "Alta",
                "value": "high"
              }
            ]
          },
          {
            "name": "contactDate",
            "type": "date",
            "label": "Fecha de contacto"
          },
          {
            "name": "notifications",
            "type": "toggle",
            "label": "Notificaciones",
            "placeholder": "Recibir actualizaciones"
          },
          {
            "name": "notes",
            "type": "textarea",
            "label": "Observaciones",
            "layout": "full",
            "length": {
              "max": 500
            }
          }
        ]
      }
    ]
  }
}
