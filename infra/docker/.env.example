COMPOSE_PROJECT_NAME=chicle-engine

API_PORT=3000
APP_PORT=8100

CHICLE_ENV=local
CHICLE_VAULT_PATH=/app/storage/vault
# Optional. Leave empty locally so Chicle creates a mounted local Vault key.
# In real servers set this from a server secret, not from a committed file.
CHICLE_SECRET_MASTER_KEY=

DB_HOST=db
DB_PORT=3306
DB_NAME=chicle_engine
DB_USER=chicle
DB_PASSWORD=chicle_secret
DB_ROOT_PASSWORD=root_secret
DB_SYNCHRONIZE=false

# Schema designer. Each visual change is always stored in schema_changes
# with its generated migration source. In local development this also writes
# a TypeORM migration file to the repo-mounted migrations directory.
CHICLE_SCHEMA_MIGRATIONS_WRITE_FILES=true
CHICLE_SCHEMA_MIGRATIONS_DIR=src/database/migrations
# Development-only safety valve. Allows owner users to drop custom_* tables
# from the DB designer. Keep false in shared/staging/production environments.
CHICLE_SCHEMA_ALLOW_DROP_TABLE=true

JWT_SECRET=change_me_in_real_environments
CHICLE_CORS_ORIGINS=http://localhost:8100,http://127.0.0.1:8100
FILES_ROOT=/app/storage/files

# Local AI assistant. V1 is local-first and provider-agnostic.
# For Docker Compose with the ai-local profile use AI_BASE_URL=http://ollama:11434/v1.
AI_ENABLED=true
AI_PROVIDER=ollama
AI_BASE_URL=http://ollama:11434/v1
# qwen2.5-coder:7b is the default local development model because it runs on
# smaller Docker Desktop memory limits. Use qwen3-coder:30b on machines with
# enough RAM assigned to Docker.
AI_CHAT_MODEL=qwen2.5-coder:7b
AI_EMBEDDING_MODEL=nomic-embed-text:v1.5
AI_TIMEOUT_MS=180000
# Short budget for interactive chat turns. If the local model does not answer in
# this window, Chicle continues with guided authoring instead of blocking the UI.
AI_FAST_TIMEOUT_MS=18000
AI_REASONING_TIMEOUT_MS=45000
AI_MAX_TOKENS=420
AI_FAST_MAX_TOKENS=140
AI_CONTEXT_WINDOW=4096
AI_KEEP_ALIVE=10m
AI_RAG_ENABLED=true
AI_RAG_MODE=keyword
AI_MAX_CONTEXT_CHUNKS=12
AI_ALLOW_PUBLISH=false

# Swagger/OpenAPI docs. Default behavior: enabled outside production,
# disabled in production unless CHICLE_SWAGGER_ENABLED=true.
CHICLE_SWAGGER_ENABLED=
CHICLE_SWAGGER_USER=
CHICLE_SWAGGER_PASSWORD=

# Development-only system reset. Keep disabled unless you are intentionally
# testing first-run setup flows on a disposable local database.
CHICLE_ALLOW_SYSTEM_RESET=false
CHICLE_RESET_KEY=change_me_for_local_reset
