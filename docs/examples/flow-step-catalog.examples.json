{
  "schemaVersion": 1,
  "domain": "flow_steps",
  "steps": [
    {
      "key": "start",
      "name": "Start",
      "type": "start",
      "position": 0,
      "outputKey": "input",
      "nextStepKey": "next",
      "config": {}
    },
    {
      "key": "query_user",
      "name": "Query user",
      "type": "dynamic_service",
      "position": 10,
      "outputKey": "user",
      "nextStepKey": "next",
      "onErrorStepKey": "error_response",
      "onTimeoutStepKey": "error_response",
      "inputMap": {
        "email": "{{input.email}}"
      },
      "config": {
        "serviceKey": "find_user",
        "timeoutMs": 8000,
        "retry": {
          "attempts": 1,
          "backoffMs": 300
        },
        "compensationServiceKey": "revert_operation"
      }
    },
    {
      "key": "parallel_queries",
      "name": "Parallel queries",
      "type": "parallel",
      "position": 20,
      "outputKey": "queries",
      "nextStepKey": "next",
      "onErrorStepKey": "error_response",
      "config": {
        "branches": [
          {
            "key": "client",
            "serviceKey": "query_client",
            "inputMap": {
              "id": "{{input.clientId}}"
            }
          },
          {
            "key": "balance",
            "serviceKey": "query_balance",
            "inputMap": {
              "clientId": "{{input.clientId}}"
            }
          }
        ]
      }
    },
    {
      "key": "process_items",
      "name": "Process items",
      "type": "foreach",
      "position": 30,
      "outputKey": "processed_items",
      "nextStepKey": "next",
      "onErrorStepKey": "error_response",
      "config": {
        "itemsPath": "input.items",
        "serviceKey": "process_item",
        "itemInputKey": "item",
        "concurrency": 4,
        "inputMap": {
          "orderId": "{{input.orderId}}"
        }
      }
    },
    {
      "key": "execute_subflow",
      "name": "Execute subflow",
      "type": "subflow",
      "position": 40,
      "outputKey": "subflow",
      "nextStepKey": "next",
      "inputMap": {
        "email": "{{input.email}}"
      },
      "config": {
        "flowKey": "validate_identity"
      }
    },
    {
      "key": "wait",
      "name": "Wait",
      "type": "delay",
      "position": 50,
      "outputKey": "wait",
      "nextStepKey": "next",
      "config": {
        "durationMs": 1000
      }
    },
    {
      "key": "emit_event",
      "name": "Emit event",
      "type": "emit_event",
      "position": 60,
      "outputKey": "event",
      "nextStepKey": "next",
      "config": {
        "eventKey": "order.validated",
        "aggregateType": "order",
        "payload": {
          "orderId": "{{input.orderId}}",
          "result": "{{steps.validation}}"
        }
      }
    },
    {
      "key": "calculate_total",
      "name": "Calculate total",
      "type": "formula",
      "position": 70,
      "outputKey": "total",
      "nextStepKey": "next",
      "config": {
        "language": "json_logic",
        "rule": {
          "*": [
            {
              "var": "input.price"
            },
            {
              "var": "input.quantity"
            }
          ]
        },
        "precision": 2
      }
    },
    {
      "key": "validate_email",
      "name": "Validate email",
      "type": "validation",
      "position": 80,
      "outputKey": "validation",
      "nextStepKey": "next",
      "onFalseStepKey": "error_response",
      "config": {
        "field": "input.email",
        "operator": "email",
        "message": "The email is not valid"
      }
    },
    {
      "key": "decide_approval",
      "name": "Decide approval",
      "type": "decision",
      "position": 90,
      "outputKey": "decision",
      "onTrueStepKey": "success_response",
      "onFalseStepKey": "error_response",
      "config": {
        "language": "json_logic",
        "rule": {
          ">=": [
            {
              "var": "input.total"
            },
            100
          ]
        }
      }
    },
    {
      "key": "front_instruction",
      "name": "Front instruction",
      "type": "action",
      "position": 100,
      "outputKey": "action",
      "nextStepKey": "next",
      "config": {
        "action": "show_modal"
      }
    },
    {
      "key": "success_response",
      "name": "Respond success",
      "type": "response",
      "position": 110,
      "outputKey": "response",
      "config": {
        "status": "success",
        "body": {
          "ok": true,
          "data": "{{steps.total}}"
        }
      }
    },
    {
      "key": "end",
      "name": "End",
      "type": "end",
      "position": 120,
      "outputKey": "end",
      "config": {}
    }
  ]
}
